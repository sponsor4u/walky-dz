# ==========================================
# Walky DZ — Algeria COD Ecommerce Platform
# Environment Variables
# ==========================================

# --- Required ---

# Supabase Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase Auth & Storage
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Setup
# First admin email — will be granted admin role on first login
ADMIN_EMAIL=admin@yourstore.com

# ==========================================
# Optional — Integrations
# ==========================================

# Google Sheets Integration
# Create a service account, download JSON key, and paste the private key here
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service@project.iam.gserviceaccount.com
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Meta Pixel (Facebook)
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Snapchat Pixel
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=

# Google Analytics 4
NEXT_PUBLIC_GA4_ID=
